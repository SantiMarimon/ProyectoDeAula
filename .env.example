# MongoDB Atlas
SPRING_DATA_MONGODB_URI=mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/<base_de_datos>

# JWT — mínimo 32 caracteres aleatorios
APP_JWT_SECRET=<cadena-aleatoria-minimo-32-caracteres>
APP_JWT_EXPIRATION=86400000

# CORS (separar con coma si hay múltiples orígenes)
CORS_ORIGINS=http://localhost

# Cloudinary (para subida de evidencias)
CLOUDINARY_CLOUD_NAME=<tu-cloud-name>
CLOUDINARY_API_KEY=<tu-api-key>
CLOUDINARY_API_SECRET=<tu-api-secret>

# Docker (no cambiar en producción)
APP_UPLOAD_DIR=/app/uploads
